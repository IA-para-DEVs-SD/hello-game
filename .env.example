# Configurações do PyBlaze
# Copie este arquivo para .env e ajuste conforme necessário

# === GERAL ===
# Modo debug (true/false)
PYBLAZE_DEBUG=false

# Nível de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)
PYBLAZE_LOG_LEVEL=INFO

# Diretório para saves
PYBLAZE_SAVE_DIR=~/.pyblaze

# === JOGO ===
# Resolução da tela (largura x altura)
PYBLAZE_SCREEN_WIDTH=1280
PYBLAZE_SCREEN_HEIGHT=720

# FPS alvo
PYBLAZE_FPS=60

# Tela cheia (true/false)
PYBLAZE_FULLSCREEN=false

# VSync (true/false)
PYBLAZE_VSYNC=true

# === AUDIO ===
# Volume master (0.0 a 1.0)
PYBLAZE_VOLUME_MASTER=0.8

# Volume música (0.0 a 1.0)
PYBLAZE_VOLUME_MUSIC=0.6

# Volume efeitos sonoros (0.0 a 1.0)
PYBLAZE_VOLUME_SFX=0.8

# === PERFORMANCE ===
# Ativar profiling (true/false)
PYBLAZE_ENABLE_PROFILING=false

# Mostrar FPS na tela (true/false)
PYBLAZE_SHOW_FPS=false

# Limite de memória em MB (0 = sem limite)
PYBLAZE_MEMORY_LIMIT=0

# === DESENVOLVIMENTO ===
# Modo headless para CI/CD (true/false)
SDL_VIDEODRIVER=dummy
SDL_AUDIODRIVER=dummy

# Ativar hot reload (true/false)
PYBLAZE_HOT_RELOAD=false

# Ativar console de debug (true/false)
PYBLAZE_DEBUG_CONSOLE=false

# === ANALYTICS ===
# Coletar analytics locais (true/false)
PYBLAZE_ENABLE_ANALYTICS=true

# Diretório para analytics
PYBLAZE_ANALYTICS_DIR=~/.pyblaze/analytics
